{
  "hosting": {
    "site": "flockos-comms",
    "public": "flockchat-public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "**", "destination": "/FlockChat.html" }
    ]
  },
  "firestore": {
    "rules": "FlockOS/Tools/Development Scripts/firestore.rules",
    "indexes": "FlockOS/Tools/firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log"
    ]
  }
}
