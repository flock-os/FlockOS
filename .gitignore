# ══════════════════════════════════════════════════════════════════════════
# FlockOS .gitignore
# ══════════════════════════════════════════════════════════════════════════

# ── OS / Editor artifacts ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Backup / temp files ──────────────────────────────────────────────────
*.bak
*.tmp
*.log
*.md
*.md.bak

# ── Google Apps Script backend files ─────────────────────────────────────
# .gs files are deployed via the Apps Script editor, not git.
*.gs

# ── Documentation text files ─────────────────────────────────────────────
# Internal docs with sensitive references; not for public repos.
*.txt

# ── Internal tools folder — never publish ────────────────────────────────
# Contains deployment guides, admin credentials, API URLs, build scripts.
FlockOS/Tools/Flock Secrets/
FlockOS/Tools/Production Notes/
FlockOS/Planning/
# ── Internal reference docs ───────────────────────────────────────────────
# Large citation/reference markdown — useful locally, not for the repo.
\#\ Code\ Citations.md
\#\ Code\ References.md

# ── Node / build artifacts (future-proofing) ─────────────────────────────
node_modules/
.env
.env.*

# ── Capacitor build output ───────────────────────────────────────────────
www/
ios/
android/

# ── Python build tools ───────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
CurrentFBPW.json

# ── Local-only utility scripts ───────────────────────────────────────────
# One-off scripts (e.g. Firestore checks, data migrations) — local only.
FlockOS/Tools/Flock Scripts/H-Check_Firestore.py
check_*.py
migrate_*.py
